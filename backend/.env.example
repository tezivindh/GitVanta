# =====================================================
# GITHUB PORTFOLIO ANALYZER - BACKEND ENVIRONMENT
# =====================================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/github_portfolio_analyzer

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# =====================================================
# AI PROVIDER CONFIGURATION
# =====================================================
# Choose your AI provider: groq, gemini, openai, anthropic
# Groq is recommended (fast, free tier, Llama models)
AI_PROVIDER=groq

# Groq API Key (Recommended - Fast & Free)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Google Gemini API Key (Alternative)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# OpenAI API Key (Optional)
# OPENAI_API_KEY=your_openai_api_key

# Anthropic API Key (Optional)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Custom AI Model (Optional - defaults based on provider)
# AI_MODEL=llama-3.3-70b-versatile
# AI_MAX_TOKENS=4096
# AI_TEMPERATURE=0.7

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
